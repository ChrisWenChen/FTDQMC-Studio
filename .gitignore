############################################
# Build directories (CMake / Make / Ninja)
############################################
build/
build-*/
cmake-build-*/
out/
dist/

############################################
# CMake generated files
############################################
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/
Makefile
compile_commands.json

############################################
# FetchContent / external dependencies
############################################
_deps/
deps/
third_party/

############################################
# Object files / libraries / executables
############################################
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe

############################################
# HPC / MPI runtime junk
############################################
*.out
*.err
*.log
slurm-*.out
slurm-*.err
core
core.*

############################################
# Editor / IDE files
############################################
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

############################################
# Python / Jupyter (future-proof)
############################################
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

############################################
# OS-specific junk
############################################
Thumbs.db

############################################
# Backup / temp files
############################################
*.bak
*.tmp
*.old

############################################
# PETSc / SLEPc build artifacts (if built in-tree by mistake)
############################################
arch-*/
petsc-*/
slepc-*/

############################################
# User-specific scripts / notes
############################################
notes/
local/
.env
